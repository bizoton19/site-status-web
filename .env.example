# Copy this file to `.env` in the project root. Vite only exposes variables prefixed with VITE_.

# Azure Functions base URL (no trailing suffix — paths below are appended)
VITE_API_BASE_URL=https://healthchker-akhghwe9adgxcqdt.eastus-01.azurewebsites.net/api

# Function or host key (?code=…) — required on every call.
VITE_API_CODE=

# --- HTTP function route names (defaults match `az functionapp function list` on app `healthchker`, rg `functions-cpsc1`)
# Poller (GET) — invoke: .../api/httppollertrigger
VITE_POLLER_FUNCTION=httppollertrigger

# URL list (GET) — .../api/statusurllistreader
VITE_URL_LIST_FUNCTION=statusurllistreader

# Site status rows (GET) — .../api/statussitestatereader
VITE_STATUS_FUNCTION=statussitestatereader

# URL add/update/delete (POST, PUT, DELETE) — .../api/urlpersister
VITE_URL_PERSISTER_FUNCTION=urlpersister
