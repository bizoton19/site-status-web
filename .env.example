# Copy this file to `.env` in the project root. Vite only exposes variables prefixed with VITE_.

# Azure Functions base URL (no trailing slash)
VITE_API_BASE_URL=https://healthchker-akhghwe9adgxcqdt.eastus-01.azurewebsites.net/api

# Required for every API call (statuses, urls, url, status, httpPollerTrigger).
# Paste your function key or host key from the Azure portal.
VITE_API_CODE=
